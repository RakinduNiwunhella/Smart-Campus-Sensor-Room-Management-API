<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Smart Campus API</display-name>

    <!--
        With Jersey's ResourceConfig + @ApplicationPath (Servlet 3.0+ model),
        Tomcat auto-discovers the application class and no servlet registration
        is strictly required. This web.xml is kept so Tomcat recognises the
        module as a web application and to confirm the URL pattern explicitly.

        jersey.config.server.provider.packages tells Jersey to scan the given
        package for @Path resources, @Provider mappers, and @Provider filters.
        This is the approach shown in the Week 08 lecture slides.
    -->
    <servlet>
        <servlet-name>JerseyServlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.smartcampus</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>JerseyServlet</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
